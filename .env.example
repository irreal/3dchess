# Copy to .env and adjust. Base URL of the multiplayer server (server/).
# For local development run `cd server && PORT=3001 npm run dev` and use:
# VITE_SERVER_URL=http://localhost:3001
VITE_SERVER_URL=https://3dchess-server.fly.dev

# Optional. Giphy API key so the spectator crowd's billboards play random GIFs.
# Get a free key at https://developers.giphy.com/. Without it the crowd shows
# colorful placeholder screens instead.
# VITE_GIPHY_API_KEY=your_giphy_api_key
